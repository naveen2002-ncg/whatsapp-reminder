# =============================================================================
# WhatsApp Reminder Bot - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
# NEVER commit `.env` to version control (it's already in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Twilio Credentials
# -----------------------------------------------------------------------------
# Get these from your Twilio Console: https://console.twilio.com/
# Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (34 chars, starts with AC)
TWILIO_ACCOUNT_SID=your_account_sid_here

# Format: 32-character hexadecimal string
# SECURITY: Rotate this immediately if accidentally exposed
TWILIO_AUTH_TOKEN=your_auth_token_here

# -----------------------------------------------------------------------------
# REQUIRED: Twilio WhatsApp Sender
# -----------------------------------------------------------------------------
# Your Twilio WhatsApp-enabled phone number
# Format: whatsapp:+<country_code><number> (e.g., whatsapp:+14155238886)
# Get this from: https://console.twilio.com/us1/develop/sandbox
# NOTE: This MUST match your verified Twilio WhatsApp sender
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# -----------------------------------------------------------------------------
# REQUIRED: Flask Application Security
# -----------------------------------------------------------------------------
# Generate a strong random secret key for session management
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# OR: openssl rand -hex 32
SECRET_KEY=your_random_secret_key_here_min_32_chars_recommended

# -----------------------------------------------------------------------------
# OPTIONAL: Application Configuration
# -----------------------------------------------------------------------------
# Flask environment mode: development | production | testing
# Default: development
FLASK_ENV=development

# Flask debug mode: true | false
# WARNING: Never use true in production
FLASK_DEBUG=true

# -----------------------------------------------------------------------------
# OPTIONAL: Database Configuration
# -----------------------------------------------------------------------------
# SQLite database file path (relative to project root)
# Default: reminders.db
DATABASE_PATH=reminders.db

# -----------------------------------------------------------------------------
# OPTIONAL: Logging Configuration
# -----------------------------------------------------------------------------
# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: DEBUG in development, INFO in production
LOG_LEVEL=DEBUG

# =============================================================================
# VALIDATION CHECKLIST
# =============================================================================
# [ ] TWILIO_ACCOUNT_SID starts with "AC" and is 34 characters
# [ ] TWILIO_AUTH_TOKEN is 32 characters (hex)
# [ ] TWILIO_WHATSAPP_FROM starts with "whatsapp:+" and has valid country code
# [ ] SECRET_KEY is at least 32 characters (64 hex chars recommended)
# [ ] .env file is NOT tracked in git (check: git check-ignore -v .env)
# =============================================================================
